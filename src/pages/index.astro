---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Mónica Uñas Premium">
  <!-- Hero -->
  <section class="min-h-screen bg-gradient-to-br from-pink-50 to-pink-100 flex items-center px-4 py-20">
    <div class="max-w-6xl mx-auto w-full">
      <h1 class="text-6xl font-bold text-pink-900 mb-6">Mónica Uñas <span class="text-pink-500">Premium</span></h1>
      <p class="text-2xl text-gray-700 mb-8">Diseños artísticos en Lomas Estrella, CDMX</p>
      <a href="https://wa.me/5551234567" class="inline-block bg-pink-500 text-white font-bold py-4 px-8 rounded-lg hover:bg-pink-600">📱 Agendar cita</a>
    </div>
  </section>

  <!-- Servicios -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-center mb-16 text-pink-900">Servicios</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="p-8 bg-pink-50 rounded-lg">
          <h3 class="text-2xl font-bold text-pink-900 mb-4">Manicure</h3>
          <p class="text-gray-600">Servicios premium de uñas</p>
        </div>
        <div class="p-8 bg-pink-50 rounded-lg">
          <h3 class="text-2xl font-bold text-pink-900 mb-4">Gel</h3>
          <p class="text-gray-600">Uñas de gel de larga duración</p>
        </div>
        <div class="p-8 bg-pink-50 rounded-lg">
          <h3 class="text-2xl font-bold text-pink-900 mb-4">Diseños</h3>
          <p class="text-gray-600">Diseños artísticos personalizados</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-12 text-center">
    <p>© 2026 Mónica Uñas Premium</p>
    <p class="text-gray-400">Efeso 4, Lomas Estrella, CDMX | +52 55 1234 5678</p>
  </footer>

  <script>
    // GSAP animations
    const gsap = window.gsap;
    gsap.from('h1', { opacity: 0, y: 30, duration: 0.8 });
    gsap.from('p', { opacity: 0, y: 20, duration: 0.8, delay: 0.2 });
  </script>
</Layout>
